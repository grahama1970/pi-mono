{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/skill_policy.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/graham/workspace/experiments/pi-mono/.claude/hooks/unset-venv.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/skill_policy.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/code_runner_guard.py\" pre-bash",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/skill_policy.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/code_runner_guard.py\" pre-write",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/skill_policy.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/graham/workspace/experiments/pi-mono/.claude/hooks/post-compact-resume.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/skill_policy.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/code_runner_guard.py\" stop",
            "timeout": 10
