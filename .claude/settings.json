    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/home/graham/workspace/experiments/pi-mono/.claude/hooks/code_runner_guard.py\" stop",
            "timeout": 10
          }
        ]
