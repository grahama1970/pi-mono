{
  "name": "@embry/pi-chat-adapter",
  "version": "0.1.0",
  "description": "D-Bus client bridge: embry-agent → SSE → ChatWell. No Pi internals modified.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
