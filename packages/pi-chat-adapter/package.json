      "import": "./dist/hook.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "dbus-next": "^0.10.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  }
}
