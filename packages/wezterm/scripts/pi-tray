#!/usr/bin/env python3
"""Pi Term KDE system tray icon via StatusNotifierItem.

Reads agent state from /tmp/pi-tray-$USER.state (JSON).
Shows workspace count and agent status in tooltip.
Menu: Show/Hide Pi Term, New Workspace, Quit.
"""

import json
import os
import signal
import subprocess
import sys
import time

PID_FILE = f"/tmp/pi-tray-{os.getenv('USER', 'unknown')}.pid"
STATE_FILE = f"/tmp/pi-tray-{os.getenv('USER', 'unknown')}.state"

STATUS_ICONS = {
    "ready": "terminal",
    "streaming": "media-playback-start",
    "offline": "terminal",
}


def read_state():
    """Read agent state from the state file."""
    try:
        with open(STATE_FILE, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {"status": "offline", "model": "", "workspaces": 0}


def show_pi-term():
    """Focus the Pi Term window."""
    subprocess.Popen(
        ["xdotool", "search", "--name", "WezTerm", "windowactivate"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def new_workspace():
    """Create a new workspace via wezterm CLI."""
    subprocess.Popen(
        ["wezterm", "cli", "spawn", "--new-window"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def quit_pi-term():
    """Clean up and exit."""
    try:
        os.unlink(PID_FILE)
    except FileNotFoundError:
        pass
    sys.exit(0)


def write_pid():
    """Write PID file for single-instance guard."""
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))


def check_single_instance():
    """Exit if another instance is already running."""
    try:
        with open(PID_FILE, "r") as f:
            pid = int(f.read().strip())
        # Check if process exists
        os.kill(pid, 0)
        print(f"pi-tray already running (PID {pid})", file=sys.stderr)
        sys.exit(0)
    except (FileNotFoundError, ValueError, ProcessLookupError, PermissionError):
        pass


def run_dbus_tray():
    """Run tray using gdbus/qdbus for KDE StatusNotifierItem."""
    write_pid()
    signal.signal(signal.SIGTERM, lambda *_: quit_pi-term())
    signal.signal(signal.SIGINT, lambda *_: quit_pi-term())

    # Try pystray first (cross-desktop), fall back to yad/zenity
    try:
        import pystray
        from PIL import Image, ImageDraw

        def create_icon(status):
            """Create a simple colored icon based on status."""
            img = Image.new("RGBA", (22, 22), (0, 0, 0, 0))
            draw = ImageDraw.Draw(img)
            colors = {
                "ready": (80, 250, 123),    # green
                "streaming": (255, 184, 108),  # orange
                "offline": (98, 114, 164),    # gray
            }
            color = colors.get(status, colors["offline"])
            # Terminal-like icon: filled rounded rect
            draw.rounded_rectangle([2, 2, 20, 20], radius=3, fill=color)
            draw.text((6, 4), ">_", fill=(40, 42, 54))
            return img

        def on_show(_icon, _item):
            show_pi-term()

        def on_new_ws(_icon, _item):
            new_workspace()

        def on_quit(_icon, _item):
            icon.stop()
            quit_pi-term()

        state = read_state()
        icon = pystray.Icon(
            "pi-term",
            create_icon(state.get("status", "offline")),
            "Pi Term",
            menu=pystray.Menu(
                pystray.MenuItem("Show Pi Term", on_show, default=True),
                pystray.MenuItem("New Workspace", on_new_ws),
                pystray.Menu.SEPARATOR,
                pystray.MenuItem("Quit", on_quit),
            ),
        )

        # Update tooltip periodically
        def update_loop(icon):
            while icon.visible:
                state = read_state()
                status = state.get("status", "offline")
                ws_count = state.get("workspaces", 0)
                model = state.get("model", "")
                tooltip = f"Pi Term - {status}"
                if ws_count > 0:
                    tooltip += f" ({ws_count} workspaces)"
                if model:
                    tooltip += f"\n{model}"
                icon.title = tooltip
                icon.icon = create_icon(status)
                time.sleep(5)

        import threading
        threading.Thread(target=update_loop, args=(icon,), daemon=True).start()
        icon.run()

    except ImportError:
        # Fallback: just write state, no GUI tray
        print("pystray not available; tray icon disabled", file=sys.stderr)
        print("Install: pip install pystray pillow", file=sys.stderr)
        # Keep running so PID file stays valid
        while True:
            time.sleep(60)


if __name__ == "__main__":
    check_single_instance()
    run_dbus_tray()
