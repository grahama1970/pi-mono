{
  "version": 1,
  "app": "SPARTA Explorer Evidence Chat",
  "base_url": "http://localhost:3002/#sparta-explorer",
  "surfaces": [
    {
      "name": "evidence-chat-workspace",
      "path": "/",
      "wait_ready": "[data-qid='sparta:button:embry-assistant']",
      "qid_compliance": true,
      "elements": [
        {
          "name": "open-chat-drawer",
          "interactions": [
            {
              "action": "click",
              "target": "[data-qid='sparta:button:embry-assistant']",
              "description": "Open Ask Embry drawer",
              "screenshot_after": true,
              "assert_min_size": { "selector": "[data-qid='sparta:button:embry-assistant']", "min_width": 44, "min_height": 44 },
              "assert_title": "[data-qid='sparta:button:embry-assistant']",
              "assert_qs_action": "[data-qid='sparta:button:embry-assistant']"
            },
            {
              "action": "wait",
              "target": "[data-qid='sparta:hud:input']",
              "timeout_ms": 5000,
              "description": "Wait for chat composer after drawer opens"
            }
          ]
        },
        {
          "name": "submit-evidence-case",
          "interactions": [
            {
              "action": "type",
              "target": "[data-qid='sparta:hud:input']",
              "value": "/create-evidence-case Given third-party FPGA vendors, which SPARTA supply-chain controls should we prioritize for CMMC Level 3?",
              "description": "Type create-evidence-case prompt"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:hud:transmit']",
              "description": "Submit evidence-case prompt",
              "screenshot_after": true,
              "assert_min_size": { "selector": "[data-qid='sparta:hud:transmit']", "min_width": 44, "min_height": 44 },
              "assert_title": "[data-qid='sparta:hud:transmit']",
              "assert_qs_action": "[data-qid='sparta:hud:transmit']"
            },
            {
              "action": "wait",
              "target": "[data-qid='sparta:evidence-workspace:tab-trace']",
              "timeout_ms": 30000,
              "description": "Wait for Evidence Workspace to open"
            },
            {
              "action": "screenshot",
              "description": "Evidence run timeline and workspace visible"
            }
          ]
        },
        {
          "name": "workspace-tabs",
          "interactions": [
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:tab-sources']",
              "description": "Open Sources tab",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:tab-sources']"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:tab-entities']",
              "description": "Open Entities tab",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:tab-entities']"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:tab-proof']",
              "description": "Open Proof tab",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:tab-proof']"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:tab-export']",
              "description": "Open Export and diagnostics tab",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:tab-export']"
            }
          ]
        },
        {
          "name": "reviewer-controls",
          "interactions": [
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:defer']",
              "description": "Defer evidence case",
              "screenshot_after": true,
              "assert_min_size": { "selector": "[data-qid='sparta:evidence-workspace:defer']", "min_width": 44, "min_height": 44 },
              "assert_title": "[data-qid='sparta:evidence-workspace:defer']"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:edit']",
              "description": "Edit evidence case answer",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:edit']"
            },
            {
              "action": "click",
              "target": "[data-qid='sparta:evidence-workspace:rerun']",
              "description": "Request rerun of latest evidence step",
              "screenshot_after": true,
              "assert_title": "[data-qid='sparta:evidence-workspace:rerun']"
            }
          ]
        }
      ]
    }
  ]
}
