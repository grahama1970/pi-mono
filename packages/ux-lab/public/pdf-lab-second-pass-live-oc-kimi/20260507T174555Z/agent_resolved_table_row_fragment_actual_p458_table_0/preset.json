{
  "schema_version": "pdf_lab.element_preset.v1",
  "required_inputs": [
    "case_id",
    "page",
    "element_id",
    "original_page_image_path",
    "annotated_page_image_path",
    "actual_json",
    "provenance"
  ],
  "common_validators": [
    "artifact_paths_exist",
    "actual_json_present",
    "no_invented_text",
    "page_matches_element_page"
  ],
  "decision_outputs": [
    "agent_resolved",
    "human_triage",
    "fixture_candidate",
    "blocker"
  ],
  "preset_id": "pdf.table.v1",
  "element_type": "table",
  "required_outputs": [
    "table_id",
    "page",
    "bbox",
    "columns",
    "rows",
    "header_rows",
    "caption",
    "notes",
    "confidence",
    "warnings",
    "evidence"
  ],
  "validators": [
    "page_image_required",
    "annotated_bbox_required",
    "rows_match_visible_text",
    "no_invented_cells",
    "bbox_does_not_cut_visible_table_content"
  ],
  "human_triage_gate": "Only escalate when visible table content and actual/candidate JSON conflict on table identity, bounds, row structure, or cell text.",
  "rendering_contract": [
    "show_original_page",
    "show_annotated_page_or_crop",
    "show_actual_json",
    "show_candidate_corrected_json_or_null",
    "show_validator_results"
  ]
}