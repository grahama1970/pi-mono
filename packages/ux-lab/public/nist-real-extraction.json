        0.12745098039215685,
        0.30082070707070707,
        0.8630717159096711,
        0.34847220989188765
      ],
      "blockType": "text",
      "text": "This publication is intended to serve a diverse group of individuals and organizations with security and privacy responsibilities including system owners, common control providers, authorizing officials, system security and privacy officers, and risk executives.",
      "qids": null,
      "tocEntries": null,
      "confidence": 0.95
    },
