      "text": "[QID_SEC_005] 1.1 PURPOSE AND APPLICABILITY",
      "qids": [
        "[QID_SEC_005]"
      ],
      "tocEntries": null,
      "confidence": 0.95
    },
    {
      "id": "block_6",
      "page": 2,
      "bbox": [
        0.12745098039215685,
        0.18592171717171718,
        0.8684802086524714,
        0.2487247544105607
      ],
      "blockType": "text",
      "text": "This publication provides a catalog of security and privacy controls for information systems and organizations to protect organizational operations and assets, individuals, other organizations, and the Nation from a diverse set of threats and risks including hostile attacks, human errors, natural disasters, structural failures, foreign intelligence entities, and privacy risks.",
      "qids": null,
      "tocEntries": null,
      "confidence": 0.95
    },
    {
      "id": "block_7",
      "page": 2,
      "bbox": [
