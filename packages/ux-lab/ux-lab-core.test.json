          "action": "click",
          "selector": "[data-testid='zoom-in']"
        },
        {
          "action": "wait",
          "ms": 100
        },
        {
          "action": "click",
          "selector": "[data-testid='zoom-reset']"
        },
        {
          "action": "wait",
          "ms": 200
        },
        {
          "action": "assert",
          "type": "text_contains",
          "selector": "[data-testid='zoom-level']",
          "text": "100%"
