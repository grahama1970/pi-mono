    {
      "id": "sidebar_renders",
      "group": "sidebar",
      "label": "Sidebar renders with projects",
      "steps": [
        {
          "action": "assert",
          "type": "exists",
          "selector": "[data-testid='project-sidebar']"
        },
        {
          "action": "assert",
          "type": "exists",
          "selector": "[data-testid='sidebar-search']"
        },
        {
          "action": "assert",
          "type": "exists",
          "selector": "[data-testid='project-music-lab-pipeline']"
        },
        {
          "action": "assert",
          "type": "exists",
          "selector": "[data-testid='project-sparta-explorer']"
        },
        {
          "action": "assert",
          "type": "exists",
          "selector": "[data-testid='project-binary-explorer']"
        },
        {
          "action": "screenshot",
          "name": "sidebar_initial"
        }
      ]
    },
    {
      "id": "sidebar_collapse",
      "group": "sidebar",
      "label": "Collapse sidebar",
      "steps": [
        {
          "action": "click",
          "selector": "[data-testid='sidebar-toggle']"
        },
        {
          "action": "wait",
          "ms": 400
        },
        {
          "action": "screenshot",
          "name": "sidebar_collapsed"
        },
        {
          "action": "assert",
          "type": "style",
          "selector": "[data-testid='project-sidebar']",
          "property": "width",
          "operator": "lt",
          "value": 60
        }
      ]
    },
    {
      "id": "sidebar_expand",
      "group": "sidebar",
      "label": "Expand sidebar",
      "steps": [
        {
          "action": "click",
          "selector": "[data-testid='sidebar-toggle']"
        },
        {
          "action": "wait",
          "ms": 400
        },
        {
          "action": "assert",
          "type": "style",
          "selector": "[data-testid='project-sidebar']",
          "property": "width",
          "operator": "gt",
          "value": 200
        }
      ]
    },
    {
      "id": "sidebar_search_filter",
      "group": "sidebar",
      "label": "Search filters project list",
      "steps": [
        {
          "action": "type",
          "selector": "[data-testid='sidebar-search']",
